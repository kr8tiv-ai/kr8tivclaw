# Required (inject at runtime, never commit real values)
OPENCLAW_GATEWAY_TOKEN_FILE=/run/secrets/openclaw_gateway_token
MISSION_CONTROL_URL=http://mission-control:8000
MISSION_CONTROL_TOKEN_FILE=/run/secrets/mission_control_token
MISSION_CONTROL_TIER=enterprise
MISSION_CONTROL_PACK_REF=engineering-delivery-pack@2
MISSION_CONTROL_TELEMETRY_ENABLED=true
MISSION_CONTROL_CROSS_TENANT_LEARNING=false
MISSION_CONTROL_CROSS_USER_LEARNING=false
MISSION_CONTROL_PERSONA_PRESET_REF=default-team
MISSION_CONTROL_PERSONA_MODE=team
MISSION_CONTROL_ONBOARDING_RECOMMENDATION_ENABLED=true
MISSION_CONTROL_ONBOARDING_PERSONALIZED_DEFAULTS=voice,uplay_chromium

# Optional model policy overrides (prefer harness defaults)
MODEL_PRIMARY=openai-codex/gpt-5.3-codex
MODEL_FALLBACKS=openai-codex/gpt-5-codex
MODEL_LOCK_ROUTES=true
MODEL_ALLOW_RUNTIME_OVERRIDE=false
MODEL_REASONING_DEFAULT=max
MODEL_REASONING_FALLBACK_BEHAVIOR=highest_or_model_default

# Optional Supermemory
SUPERMEMORY_API_KEY_FILE=/run/secrets/supermemory_api_key
SUPERMEMORY_CONTAINER_TAG=tenant-acme

# Optional Telegram
TELEGRAM_BOT_TOKEN_FILE=/run/secrets/telegram_bot_token

# Optional watchdog
WATCHDOG_WEBHOOK_URL=https://example.com/watchdog
